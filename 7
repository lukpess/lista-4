/* 7) crie uma função que recebe como argumento um vetor de inteiros de tamanho 10 ainda um número inteiro qualquer.
 * Sua função deve retornar a posição do número no vetor caso o número esteja no vetor ou -1 caso contrário.  */

#include <stdio.h>
int retornavet(int vet[], int num) {
    for (int i=0; i<10; i++) {
        if (num == vet[i]) {
            return i;
        }
    }
    return -1;
}
void main() {
    int vet[10];
    int user;
    int resultado;

    for (int i=0; i<10; i++) {
        printf("Digite um numero: ");
        scanf("%d", &vet[i]);
    }
    printf("digite um numero qualquer \n");
    scanf("%d", &user);

    resultado = retornavet(vet, user);

    if (resultado != -1)
        printf("Achei! Posicao: %d\n", resultado);
    else
        printf("Número não encontrado.\n: %d", resultado);
}
