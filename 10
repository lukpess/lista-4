/*10) Escreva um programa que leia um vetor V1 de 10 elementos. O programa deve copiar
 *os elementos de V1 para um segundo vetor V2, mas de forma que V2 não contenha nenhum
 *elemento repetido. */

#include <stdio.h>

void main() {
    int vet[10] = {};
    int vet2[10] = {};
    int tam2 = 0;

    for (int i = 0; i < 10; i++) {
        scanf("%d", &vet[i]);
    }

    for (int i = 0; i < 10; i++) {
        int repetido = 0;
        for (int j = 0; j < tam2; j++){
            if (vet[i] == vet2[j]) {
                repetido = 1;
                break;
            }
        }
        if (!repetido) { //  se NÃO é repetido
            vet2[tam2] = vet[i];
            tam2++;
        }

    }
    for (int i = 0; i < tam2; i++) {
        printf("%d ", vet2[i]);
    }
}
