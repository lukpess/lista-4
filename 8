/*8) Escreva uma função que receba um vetor de inteiros e seu tamanho como argumentos e retorne a quantidade de números pares.  */

#include <stdio.h>

int qtdpares(int vet[], int tamanho) {
    int par=0;
    for (int i = 0; i < tamanho; i++) {
        if (vet[i] % 2 == 0) {
            par++;
        }
    }
    return par;
}

void main() {
    int par = 0;
    int tamanho;
    int resultado;

    printf("Digite o valor do tamanho do vetor: ");
    scanf("%d", &tamanho);
    int vet[tamanho];

    for (int i = 0; i < tamanho; i++) {
        scanf("%d", &vet[i]);
    }

    resultado = qtdpares(vet, tamanho);

    printf("O valor da pares eh %d\n", resultado);
}
