/* Escreva um programa que receba 10 números inteiros do usuário e os armazene em um array. 
Em seguida, o programa deve varrer o array para encontrar e mostrar na tela qual é o maior 
número digitado e em qual posição (índice) do array ele está e mostre a soma dos valores array.  */

#include <stdio.h>

void main() {
    int numeros[10] = {};
    int maiornum = 0, posicao;
    int soma=0;

    for (int i = 0; i < 10; i++) { //laço de repetição para ler os numeros do usuario
        printf("digite um numero: ");
        scanf("%d", &numeros[i]);
    }

    for (int i = 0; i < 10; i++) {
        if (numeros[i] > maiornum) {
            //condição para varrer e ler o maior numero
            maiornum = numeros[i];
            posicao = i;
        }
    }
    for (int i = 0; i < 10; i++) {//laço de repetição para somar os numeros
        soma += numeros[i];
    }

    printf("maior numero: %d, posicao %d, soma dos numeros e: %d", maiornum, posicao, soma);
}
