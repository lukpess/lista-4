/*Dada uma matriz quadrada de ordem 4 (dimensão 4×4) preenchida com números
inteiros, faça um programa que determine e exiba:
Os elementos da diagonal principal.
Os elementos da diagonal secundária.*/

#include <stdio.h>
 
#define N 4 //localizar e substituir
 
int main() {
    int matriz[N][N];
    int i, j;
 
    // Leitura dos elementos
    printf("Digite os elementos da matriz 4x4:\n");
    for (i = 0; i < N; i++) {
        for (j = 0; j < N; j++) {
            printf("Elemento [%d][%d]: ", i, j);
            scanf("%d", &matriz[i][j]);
        }
    }
 
    // Exibe a matriz
    printf("\nMatriz 4x4:\n");
    for (i = 0; i < N; i++) {
        for (j = 0; j < N; j++) {
            printf("%6d ", matriz[i][j]);
        }
        printf("\n");
    }
 
    // Diagonal principal: posições onde i == j
    printf("\nDiagonal principal:\n  ");
    for (i = 0; i < N; i++) {
        printf("%d ", matriz[i][i]);
    }
    printf("\n");
 
    // Diagonal secundária: posições onde i + j == N - 1
    printf("\nDiagonal secundaria:\n  ");
    for (i = 0; i < N; i++) {
        printf("%d ", matriz[i][N - 1 - i]);
    }
    printf("\n");
 
    return 0;
}
