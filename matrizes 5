/* Exercício 5 - Matrizes
Crie um programa que leia uma matriz de inteiros 4×4. O programa deve calcular e
mostrar:
A soma dos elementos de cada linha individualmente.
A soma dos elementos de cada coluna individualmente.*/

#include <stdio.h>

int main() {
    int matriz[4][4];
    int i, j;
    int somaLinha, somaColuna;

    
    // Leitura dos elementos
    printf("Digite os elementos da matriz 4x4:\n");
    for (i = 0; i < 4; i++) {
        for (j = 0; j < 4; j++) {
            printf("Elemento [%d][%d]: ", i, j);
            scanf("%d", &matriz[i][j]);
        }
    }

    // Exibe a matriz
    printf("\nMatriz 4x4:\n");
    for (i = 0; i < 4; i++) {
        for (j = 0; j < 4; j++) {
            printf("%6d ", matriz[i][j]);
        }
        printf("\n");
    }

    // Soma de cada linha
    printf("\nSoma por linha:\n");
    for (i = 0; i < 4; i++) {
        somaLinha = 0;
        for (j = 0; j < 4; j++) {
            somaLinha += matriz[i][j];
        }
        printf("  Linha %d: %d\n", i, somaLinha);
    }

    // Soma de cada coluna
    printf("\nSoma por coluna:\n");
    for (j = 0; j < 4; j++) {
        somaColuna = 0;
        for (i = 0; i < 4; i++) {
            somaColuna += matriz[i][j];
        }
        printf("  Coluna %d: %d\n", j, somaColuna);
    }

    return 0;
}
